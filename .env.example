# Instagram credentials (filled during `ig-agent login`)
IG_USERNAME=
IG_PASSWORD=
IG_TOTP_SECRET=            # optional; base32 TOTP seed if 2FA enabled
IG_PROXY=                  # optional; http://user:pass@host:port (sticky, one per account)

# Challenge resolver — email inbox for IG security codes
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=                 # app-password, not real password

# LLM providers (at least one required — OpenRouter covers 80%)
OPENROUTER_API_KEY=        # https://openrouter.ai/keys
GROQ_API_KEY=              # https://console.groq.com — optional, fastest
GEMINI_API_KEY=            # https://aistudio.google.com — optional, highest daily
CEREBRAS_API_KEY=          # https://cloud.cerebras.ai — optional, 1M tok/day

# Stock media
PEXELS_API_KEY=            # https://www.pexels.com/api — 20k req/mo free
PIXABAY_API_KEY=           # https://pixabay.com/api — 100 req/min free (covers images + music)

# Music sources (all optional — local data/music/ cache is always tried first)
FREESOUND_API_KEY=         # https://freesound.org/apiv2/apply — CC0 filter, commercial-OK

# Reddit question harvester (optional — only needed when reddit_subs is set)
REDDIT_CLIENT_ID=           # https://www.reddit.com/prefs/apps — create a "script" app
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=          # e.g. "ig-agent by u/yourhandle"

# Image generation (cloud fallback)
POLLINATIONS_TOKEN=        # https://pollinations.ai — optional, permanent free

# Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cloudflare R2 (optional — posted media is kept local when unset)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=            # e.g. https://media.mypage.com (if you've attached a custom domain)

# Dashboard auth (optional — no auth when unset; binds 127.0.0.1 by default)
DASH_USER=
DASH_PASS=

# ComfyUI local image generation (optional — needs a GPU)
# Point at a running ComfyUI instance; photo/human_photo will prefer it
# over Pollinations when set. Leave empty to stick with cloud generation.
COMFYUI_URL=
# Drop a workflow JSON export into data/comfyui_workflows/ if you want to
# override the built-in SDXL text-to-image skeleton.

# System
LOG_LEVEL=INFO
