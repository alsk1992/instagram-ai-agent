# ══════════════════════════════════════════════════════════════════════
#  instagram-ai-agent — environment template
#
#  Most users: run `ig-agent setup` — it writes the Phase 1 keys for you.
#  This file is what `.env` looks like when you edit it directly, grouped
#  so you only see optional stuff if you scroll.
# ══════════════════════════════════════════════════════════════════════


# ╔══════════════════════════════════════════════════════════════════════╗
# ║  PHASE 1 — REQUIRED to generate posts  (fill these, nothing else)   ║
# ╚══════════════════════════════════════════════════════════════════════╝

# Free API key for the AI that writes + rates posts. `ig-agent setup`
# opens your browser here and validates the key live.
OPENROUTER_API_KEY=          # https://openrouter.ai/keys


# ╔══════════════════════════════════════════════════════════════════════╗
# ║  PHASE 2 — Connect Instagram (TWO paths, pick one)                  ║
# ╚══════════════════════════════════════════════════════════════════════╝
#
# PATH A — Laptop / home WiFi  (plain u/p is fine)
#   Your home IP is trusted by Instagram's risk model. Set:
#     IG_USERNAME=yourhandle
#     IG_PASSWORD=yourpassword
#   That's it — the agent logs in via instagrapi's mobile-app API on first run.
#
# PATH B — VPS / server / new IP  (cookie-jar path is required in 2026)
#   Fresh-account u/p from a server IP triggers challenge_required almost every
#   time. The agent's full-cookie-jar path skips /login entirely (zero challenge
#   surface). Easiest capture: install the Cookie-Editor extension, log into
#   instagram.com in that browser, click Cookie-Editor → Export → JSON, then
#   run `ig-agent setup --with-login` and pick the VPS branch to paste it in —
#   the wizard validates cookies live before writing them. Or set manually:
#     IG_USERNAME=yourhandle          (still needed so session file is named)
#     IG_SESSIONID=...
#     IG_DS_USER_ID=...
#     IG_CSRFTOKEN=...
#     IG_MID=...
#     IG_DID=...
#     IG_DATR=...
#     IG_RUR=...
#     IG_SHBID=...
#     IG_SHBTS=...
#     IG_NRCB=...
#   With IG_SESSIONID + IG_DS_USER_ID + IG_CSRFTOKEN present, the agent takes
#   the cl.set_settings() path and never calls cl.login(). See Phase 5 for the
#   supplementary cookies + UA pinning that extend session survival time.

IG_USERNAME=
IG_PASSWORD=

# Force u/p + TOTP login, ignoring any cookies in this file.
# Options: (blank) = auto-pick cookie-then-u/p; userpass = skip cookies entirely.
# Set to `userpass` when you know cookies are failing (CSRF errors, web-cookie
# vs mobile-client mismatch) and want instagrapi's native mobile login flow.
IG_AUTH_MODE=

# Residential / 4G mobile proxy — non-negotiable if running from VPS. Bind
# it BEFORE first login; the cookie jar above was extracted on the user's
# home IP, and Instagram correlates cookie ASN with subsequent traffic.
# Format: http://user:pass@host:port
# Providers: Smartproxy (mobile), IPRoyal, Bright Data.
IG_PROXY=

# PATH B cookies — fill these when running from VPS (see above).
# Extract via Cookie-Editor in the browser where you're logged into IG.
IG_SESSIONID=
IG_DS_USER_ID=
IG_CSRFTOKEN=
IG_MID=
IG_DID=
IG_DATR=
IG_RUR=
IG_SHBID=
IG_SHBTS=
IG_NRCB=


# ╔══════════════════════════════════════════════════════════════════════╗
# ║  PHASE 3 — Email-code challenge auto-resolver (optional)            ║
# ╚══════════════════════════════════════════════════════════════════════╝
#
# If Instagram sends an email-code challenge during login and these are
# set, the agent reads the inbox + types the code automatically. Without
# them, the CLI prompts and you paste the code manually (fine for desktop,
# breaks if you're running `ig-agent run` detached from a terminal).
# Gmail users: create an App Password at https://myaccount.google.com/apppasswords
# and paste it as IMAP_PASS (NOT your regular password).
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=


# ╔══════════════════════════════════════════════════════════════════════╗
# ║  PHASE 4 — Optional free-tier AI fallbacks (extra quota headroom)   ║
# ╚══════════════════════════════════════════════════════════════════════╝

GROQ_API_KEY=                # https://console.groq.com — fastest
GEMINI_API_KEY=              # https://aistudio.google.com — highest daily quota
CEREBRAS_API_KEY=            # https://cloud.cerebras.ai — 1M tokens/day

# Stock video / photos — only needed if you enabled reel_stock in setup.
PEXELS_API_KEY=              # https://www.pexels.com/api — 20k/mo free
PIXABAY_API_KEY=             # https://pixabay.com/api — 100/min free

# Free CC0 music + sound library (for reels).
FREESOUND_API_KEY=           # https://freesound.org/apiv2/apply

# Free AI image fallback (no GPU needed).
POLLINATIONS_TOKEN=          # https://pollinations.ai — free, permanent

# Telegram alerts when something needs attention.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ╔══════════════════════════════════════════════════════════════════════╗
# ║  PHASE 5 — ADVANCED (only touch these if you know why)              ║
# ╚══════════════════════════════════════════════════════════════════════╝

# 2FA TOTP secret (base32), if enabled on the IG account.
IG_TOTP_SECRET=

# Geographic coherence — set to match where the IG account was created.
# IG_COUNTRY_CODE = ISO alpha-2 (US, GB, DE). IG_TIMEZONE_OFFSET = seconds
# from UTC (-14400 = EDT, 0 = UTC, 3600 = CET). IG_LOCALE = en_US, en_GB.
IG_COUNTRY_CODE=
IG_TIMEZONE_OFFSET=
IG_LOCALE=
IG_USER_AGENT=

# Supplementary cookies — marginal trust-signal improvements on top of the
# 10 required cookies in Phase 2. Only fill if you copy-paste the full
# Cookie-Editor export; easiest via `ig-agent setup --with-login` VPS branch.
IG_WD=                       # window dimensions
IG_DPR=                      # device pixel ratio
IG_IG_LANG=                  # UI locale
IG_PS_L=                     # Accounts-Center SSO (2024+)
IG_PS_N=                     # Accounts-Center SSO (2024+)
IG_FBM_APPID=                # FB SSO remember-me seed
IG_MCD=                      # mobile config delivery token
IG_CCODE=                    # country code hint

# Load a full instagrapi session JSON exported from another machine.
IG_SESSION_FILE=

# Days between forced password re-logins. 0 = never (recommended in 2026;
# every relogin is a suspicion event on IG's risk model).
IG_SESSION_REFRESH_DAYS=0

# TLS/HTTP-2 browser impersonation (requires `pip install .[tls]`). Swaps
# instagrapi's plain requests.Session for curl_cffi so Meta's JA3/JA4
# classifier doesn't flag the handshake. Default profile is a good match.
# Set to "off" to disable.
IG_TLS_IMPERSONATE=chrome131_android

# Fresh accounts get a 14-day warmup ramp: days 1-7 post nothing. For an
# account that already posts regularly, set to 1 to skip the ramp.
IG_SKIP_WARMUP=

# One-shot pipeline confirmation. ~3 min after first orchestrator start
# the agent posts ONE quote card to verify the LLM → image → upload chain
# works on this account. Bypasses the warmup gate for that single post,
# then drops a state stamp so it never fires again. Telegram alerts you
# with the post URL on success or the exact error on failure. Set to 1 to
# enable; the setup wizard prompts for it on fresh installs.
IG_SMOKE_POST=

# Reddit question harvester (niche-specific, set reddit_subs in niche.yaml first).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=           # e.g. "ig-agent by u/yourhandle"

# Local ComfyUI image generation (needs a GPU — skip on laptop).
COMFYUI_URL=

# Permanent off-host storage for posted media (Cloudflare R2).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=               # https://media.yourdomain.com

# Dashboard auth (leave blank for 127.0.0.1-only, no password).
DASH_USER=
DASH_PASS=

LOG_LEVEL=INFO
