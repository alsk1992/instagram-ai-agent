# ══════════════════════════════════════════════════════════════════════
#  instagram-ai-agent — environment template
#
#  Copy to .env and fill in. The INSTAGRAM section is the most important
#  one — getting the fingerprint + cookies right avoids 90% of the
#  "email code" challenges bot users hit on first login.
# ══════════════════════════════════════════════════════════════════════


# ─── Instagram credentials ────────────────────────────────────────────
IG_USERNAME=
IG_PASSWORD=

# Optional — 2FA base32 seed if you've got TOTP on the account.
IG_TOTP_SECRET=

# Optional but STRONGLY recommended — sticky HTTP(S) or SOCKS proxy.
# A new-IP login from a residential-proxy IP looks less suspicious than
# a cloud DC IP. One proxy per account, don't rotate.
#   Format:  http://user:pass@host:port
#   Provider hints: Smartproxy, Bright Data, IPRoyal, Storm.
IG_PROXY=


# ─── CHALLENGE AVOIDANCE: geographic coherence ────────────────────────
# Instagram pins the first successful login's country/timezone to the
# account. Logging in from a different region triggers a challenge.
# Set these to match wherever YOUR IG account was originally created.
#
# Find yours: IG_COUNTRY_CODE is ISO 3166 alpha-2 (e.g. US, GB, DE).
# IG_TIMEZONE_OFFSET is SECONDS from UTC (NOT hours): -14400 = EDT,
# 0 = UTC, 3600 = CET. IG_LOCALE is lang_COUNTRY (e.g. en_US, en_GB).
IG_COUNTRY_CODE=
IG_TIMEZONE_OFFSET=
IG_LOCALE=
IG_USER_AGENT=


# ─── CHALLENGE AVOIDANCE: direct cookie paste (RECOMMENDED) ───────────
# Cookies ARE the auth. Paste as many as you can — the more you provide,
# the cleaner the handoff. With a full set (sessionid + ds_user_id +
# csrftoken + the rest), the agent uses cl.set_settings() directly:
# ZERO /login call, ZERO challenge surface. This is the gold-standard
# way to boot on a fresh VPS without triggering IG's suspicious-login
# checks, and it's the same strategy every serious IG automation uses.
#
# How to extract (takes 60 seconds):
#   1. Log in to instagram.com in your browser
#   2. DevTools (F12) → Application → Cookies → https://www.instagram.com
#   3. For each row below, copy the "Value" column into the matching env
#
# Minimum (fallback path — login_by_sessionid):
#   IG_SESSIONID         sessionid
#
# Full set (best path — no /login call at all):
#   IG_SESSIONID         sessionid
#   IG_DS_USER_ID        ds_user_id
#   IG_CSRFTOKEN         csrftoken
#   IG_MID               mid                  ← ~20-year cookie, treat as permanent
#   IG_DID               ig_did
#   IG_DATR              datr                 ← cross-Meta browser ID, 2yr TTL
#   IG_RUR               rur                  ← HMAC-signed, rewrites silently if stale
#   IG_SHBID             shbid
#   IG_SHBTS             shbts
#   IG_NRCB              ig_nrcb
#
# Supplementary (nice-to-haves for continuity, not required):
#   IG_WD                wd                   ← window dimensions
#   IG_DPR               dpr                  ← device pixel ratio
#   IG_IG_LANG           ig_lang              ← UI locale
#   IG_PS_L              ps_l                 ← Accounts-Center SSO (2024+)
#   IG_PS_N              ps_n                 ← Accounts-Center SSO (2024+)
#   IG_FBM_APPID         fbm_124024574287414  ← FB SSO remember-me seed
#   IG_MCD               mcd                  ← mobile config delivery token
#   IG_CCODE             ccode                ← country code hint
IG_SESSIONID=
IG_DS_USER_ID=
IG_CSRFTOKEN=
IG_MID=
IG_DID=
IG_DATR=
IG_RUR=
IG_SHBID=
IG_SHBTS=
IG_NRCB=
IG_WD=
IG_DPR=
IG_IG_LANG=
IG_PS_L=
IG_PS_N=
IG_FBM_APPID=
IG_MCD=
IG_CCODE=


# ─── CHALLENGE AVOIDANCE: pre-existing session file (advanced) ────────
# Point at an instagrapi session JSON (e.g. `dump_settings` output from
# another box) to skip login entirely. The agent will copy it into
# data/sessions/<username>.json on first use.
IG_SESSION_FILE=

# ─── SESSION REFRESH CADENCE ─────────────────────────────────────────
# Days after which the agent forces a fresh password login. Default 0
# (disabled) — per 2026 instagrapi best practices, every `relogin()` is
# a high-value suspicion event for IG's risk models. The correct
# pattern is load_settings forever + relogin only on LoginRequired.
# Only set a positive value if you have field evidence your account is
# dying on a clock. Rare in 2026.
IG_SESSION_REFRESH_DAYS=0


# ─── TLS / HTTP-2 BROWSER IMPERSONATION ──────────────────────────────
# instagrapi ships plain requests.Session. Meta's server-side JA3/JA4
# + Akamai-h2 classifier flags it as bot traffic immediately. When
# `pip install .[tls]` is active, the agent swaps instagrapi's sessions
# for curl_cffi sessions that impersonate a real browser handshake.
# Field reports: challenge rate drops from ~80% to ~12% on mobile
# endpoints when active.
#
# Default profile is chrome131_android (closest OSS match to real IG
# Android OkHttp/BoringSSL handshake). Override with any curl_cffi
# target: chrome146, chrome131_android, safari18_ios, etc.
# Set to "off" to disable even when curl_cffi is installed.
IG_TLS_IMPERSONATE=chrome131_android


# ─── Email challenge resolver ─────────────────────────────────────────
# When IG sends a verification code to your email, the agent reads it
# via IMAP automatically. Without this, the CLI falls back to asking
# you to paste the code manually in the terminal (which works interactively
# but breaks when `ig-agent run` is daemonised).
#
# Gmail users: generate an App Password at
#   https://myaccount.google.com/apppasswords
# and paste it as IMAP_PASS (NOT your regular password).
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=


# ─── LLM providers ────────────────────────────────────────────────────
# At least ONE is required. OpenRouter covers 29 free models including
# Llama 3.3, Mistral, and Qwen — usually enough on its own. Adding more
# enables automatic fallback when any provider has a hiccup.
OPENROUTER_API_KEY=          # https://openrouter.ai/keys
GROQ_API_KEY=                # https://console.groq.com — fastest
GEMINI_API_KEY=              # https://aistudio.google.com — highest daily quota
CEREBRAS_API_KEY=            # https://cloud.cerebras.ai — 1M tok/day


# ─── Stock media (for reel_stock format) ──────────────────────────────
# At least one of these is required IF you enabled the reel_stock format
# in the setup wizard. Without them, the format_picker auto-skips reels.
PEXELS_API_KEY=              # https://www.pexels.com/api — 20k req/mo free
PIXABAY_API_KEY=             # https://pixabay.com/api — 100 req/min, also music


# ─── Music sources (all optional) ─────────────────────────────────────
# local data/music/ folder is tried first. Set these to expand the pool.
FREESOUND_API_KEY=           # https://freesound.org/apiv2/apply — CC0 filter


# ─── Reddit question harvester (optional) ─────────────────────────────
# Only needed when reddit_subs is set in niche.yaml.
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=           # e.g. "ig-agent by u/yourhandle"


# ─── Cloud image generation fallback (optional) ───────────────────────
POLLINATIONS_TOKEN=          # https://pollinations.ai — free, permanent


# ─── Local image generation (optional — GPU required) ────────────────
# Point at a running ComfyUI instance. photo / human_photo / carousel-
# repurpose / story_carousel generators will prefer it over Pollinations
# when set. Leave empty to stick with cloud generation.
COMFYUI_URL=


# ─── Alerts (optional) ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ─── Media persistence (optional) ────────────────────────────────────
# When unset, posted media stays on the local disk. Setting R2 keeps
# a permanent copy off-host + gives a public URL for the dashboard.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=               # https://media.yourdomain.com


# ─── Dashboard auth (optional) ───────────────────────────────────────
# When unset, dashboard has no auth and binds 127.0.0.1 only.
DASH_USER=
DASH_PASS=


# ─── Warmup bypass ───────────────────────────────────────────────────
# Fresh accounts get a 14-day warmup ramp: days 1-7 post NOTHING (by
# design — fresh accounts posting on day 1 is a bot signature). For an
# ESTABLISHED account that already has post history + followers, you
# can skip the ramp entirely. Leave blank / "0" for new accounts.
IG_SKIP_WARMUP=


# ─── System ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
